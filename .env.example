# ── Discord ──────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=your_server_id_here

# ── Channel IDs (right-click channel → Copy ID in Discord) ──
CHANNEL_ALERTS=
CHANNEL_TRADING_DESK=
CHANNEL_TREASURY=
CHANNEL_CAMP_MARKETPLACE=
CHANNEL_CONTENT_PIPELINE=
CHANNEL_DAILY_DIGEST=
CHANNEL_PROJECT_MGMT=
CHANNEL_BROWSER_OPS=

# ── Digest frequency (hours between digest posts) ────────
# 24 = once daily at 8AM UTC (default)
# 4  = every 4 hours (0AM, 4AM, 8AM, 12PM, 4PM, 8PM UTC)
# 6  = every 6 hours
DIGEST_INTERVAL_HOURS=24

# ── LLM Providers ────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Web3 ─────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
GOLDBACKBOND_PROGRAM_ID=
CAMP_IDL_PROGRAM_ID=
LAYERZERO_ENDPOINT=

# ── Security ─────────────────────────────────────────────
SECURITY_TOKEN=changeme_generate_random_32chars
LOG_DB_PATH=./logs/openchief.db

# ── Premium Modules (set true to enable) ─────────────────
ENABLE_CLICKUP=false
CLICKUP_API_KEY=

ENABLE_MEMORY_GRAPH=false
SUPABASE_URL=
SUPABASE_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=openchief-memory

ENABLE_BROWSER_OPS=false
ENABLE_PENTHOUSE_PAPI=false
